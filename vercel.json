{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "event-booking-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/static/(.*)",
      "destination": "/event-booking-app/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/event-booking-app/index.html"
    }
  ]
}
